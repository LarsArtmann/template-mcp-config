#!/bin/sh
# Commit message hook for MCP Configuration Template
# Validates commit messages against Conventional Commits

echo "📝 Validating commit message..."

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

# Get the commit message
COMMIT_MSG=$(cat "$1")

# Define allowed types
TYPES="feat|fix|docs|style|refactor|test|chore|perf|ci|hotfix"

# Define allowed scopes
SCOPES="config|server|schema|validation|scripts|deps|docs|lint|format|workflow|security|config"

# Conventional commit regex
COMMIT_REGEX="^(${TYPES})(\(${SCOPES}\))?!?: .{1,50}"

# Check for merge commits
if echo "$COMMIT_MSG" | grep -qE "^(Merge branch|Merge pull request)"; then
    echo "${GREEN}✅ Merge commit detected, skipping validation${NC}"
    exit 0
fi

# Check for fixup/squash commits
if echo "$COMMIT_MSG" | grep -qE "^(fixup|squash)!"; then
    echo "${GREEN}✅ Fixup/Squash commit detected, skipping validation${NC}"
    exit 0
fi

# Validate the commit message format
if ! echo "$COMMIT_MSG" | head -1 | grep -qE "$COMMIT_REGEX"; then
    echo "${RED}❌ Invalid commit message format${NC}"
    echo ""
    echo "Expected format: <type>(<scope>): <description>"
    echo ""
    echo "Allowed types: ${TYPES}"
    echo "Allowed scopes: ${SCOPES}"
    echo ""
    echo "Examples:"
    echo "  feat(server): add context7 MCP server"
    echo "  fix(config): correct package name"
    echo "  docs(readme): update installation guide"
    echo ""
    exit 1
fi

# Check message length (first line)
FIRST_LINE=$(echo "$COMMIT_MSG" | head -1)
if [ ${#FIRST_LINE} -gt 72 ]; then
    echo "${RED}❌ Commit message too long (max 72 characters)${NC}"
    exit 1
fi

echo "${GREEN}✅ Commit message format is valid${NC}"
exit 0
