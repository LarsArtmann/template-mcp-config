#!/bin/sh
# Pre-commit hook for MCP Configuration Template
# This hook runs linting and formatting checks before each commit

echo "🔍 Running pre-commit checks..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Check if bun is available
if ! command -v bun &> /dev/null; then
    echo "${YELLOW}⚠️  Bun not found, skipping pre-commit checks${NC}"
    exit 0
fi

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
JS_FILES=$(echo "$STAGED_FILES" | grep -E '\.(js|ts|json|md|yaml|yml)$' || true)

if [ -z "$JS_FILES" ]; then
    echo "${GREEN}✅ No relevant files to check${NC}"
    exit 0
fi

# Run prettier check on staged files
echo "📝 Checking code formatting..."
echo "$JS_FILES" | xargs bunx prettier --check 2>/dev/null
if [ $? -ne 0 ]; then
    echo "${RED}❌ Code formatting issues found. Run 'bun run format' to fix.${NC}"
    exit 1
fi
echo "${GREEN}✅ Code formatting OK${NC}"

# Run eslint check on staged JS files
JS_STAGED=$(echo "$STAGED_FILES" | grep -E '\.(js|ts)$' || true)
if [ -n "$JS_STAGED" ]; then
    echo "🔧 Running ESLint..."
    echo "$JS_STAGED" | xargs bunx eslint 2>/dev/null
    if [ $? -ne 0 ]; then
        echo "${RED}❌ ESLint issues found. Fix them before committing.${NC}"
        exit 1
    fi
    echo "${GREEN}✅ ESLint OK${NC}"
fi

# Validate JSON files
JSON_FILES=$(echo "$STAGED_FILES" | grep -E '\.json$' || true)
if [ -n "$JSON_FILES" ]; then
    echo "📋 Validating JSON files..."
    for file in $JSON_FILES; do
        node -e "JSON.parse(require('fs').readFileSync('$file'))" 2>/dev/null
        if [ $? -ne 0 ]; then
            echo "${RED}❌ Invalid JSON in $file${NC}"
            exit 1
        fi
    done
    echo "${GREEN}✅ JSON validation OK${NC}"
fi

echo "${GREEN}✅ All pre-commit checks passed!${NC}"
exit 0
